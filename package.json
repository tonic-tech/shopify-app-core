{
  "name": "@tonic/shopify-app-core",
  "version": "0.1.0",
  "description": "Shared utilities for Tonic Shopify apps (Remix + Prisma)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./handlers": {
      "import": "./dist/handlers/index.js",
      "types": "./dist/handlers/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "@prisma/client": "^5.0.0",
    "@remix-run/node": "^2.0.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "@sentry/remix": {
      "optional": true
    }
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@remix-run/node": "^2.15.0",
    "@types/node": "^25.3.5",
    "typescript": "^5.5.0",
    "zod": "^3.23.0"
  },
  "author": "Tonic Tech",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/tonic-tech/shopify-app-core.git"
  }
}
